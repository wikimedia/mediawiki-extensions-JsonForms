{
	"root": true,
	"extends": [
		"wikimedia/client",
		"wikimedia/mediawiki"
	],
	"rules": {
		"mediawiki/no-unlabeled-buttonwidget": "off",
		"compat/compat": "warn",
		"camelcase": "warn",
		"no-undef": "warn",
		"no-shadow": "warn",
		"no-console": "warn",
		"no-implicit-globals": "warn",
		"no-underscore-dangle": "warn",
		"no-return-assign": "warn",
		"no-var": "warn",
		"no-control-regex": "warn",
		"no-bitwise": "warn",
		"max-statements-per-line": "warn",
		"no-empty": "warn",
		"no-loop-func": "warn",
		"prefer-regex-literals": "warn",
		"eqeqeq": "warn",
		"no-fallthrough": "warn",
		"no-unreachable": "warn",
		"no-new": "warn",
		"no-alert": "warn",
		"no-unused-expressions": "warn",
		"new-cap": "warn",
		"no-misleading-character-class": "warn",
		"no-use-before-define": "warn",
		"no-proto": "warn",
		"no-self-compare": "warn",
		"es-x/no-regexp-lookbehind-assertions": "warn",
		"no-cond-assign": "warn",
		"no-redeclare": "warn",
		"no-unused-vars": "warn",
		"es-x/no-string-prototype-replaceall": "warn",
		"no-prototype-builtins": "warn",
		"no-unmodified-loop-condition": "warn",
		"no-unsafe-finally": "warn",
		"prefer-const": "warn",
		"no-void": "warn",
		"block-scoped-var": "warn",
		"getter-return": "warn",
		"array-callback-return": "warn",
		"no-extend-native": "warn",
		"no-constant-condition": "warn",
		"es-x/no-regexp-unicode-property-escapes": "warn",
		"no-new-func": "warn",
		"no-useless-escape": "warn",
		"unicorn/no-invalid-remove-event-listener": "warn",
		"no-useless-concat": "warn",
		"mediawiki/no-nodelist-unsupported-methods": "warn",
		"no-constant-binary-expression": "warn",
		"no-func-assign": "warn",
		"unicorn/prefer-string-slice": "warn",
		"no-sequences": "warn",
		"no-label-var": "warn",
		"no-useless-call": "warn",
		"no-self-assign": "warn"
	}
}
