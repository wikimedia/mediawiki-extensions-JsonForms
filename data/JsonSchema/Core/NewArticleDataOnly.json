{
	"type": "object",
	"$id": "NewArticleDataOnly",
	"@type": "JsonForms default schema",
	"x-compact": true,
	"x-css-class": "jsonforms-outerform",
	"required": [],
	"definitions": {
		"editor_wikieditor": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "wikieditor"
		},
		"editor_visualeditor": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "visualeditor"
		},
		"editor_jsoneditor": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input": "jsoneditor"
		},
		"editor_source": {
			"type": "string",
			"x-compact": true,
			"x-format": "textarea",
			"x-input-config": {
				"autosize": true,
				"rows": 6
			}
		},
		"newSchema": {
			"type": "object",
			"$id": "SelectSchema",
			"x-watch": "schema",
			"title": "Edit schema",
			"properties": {
				"schema": {
					"type": "string",
					"title": "JSON Schema",
					"description": "Manage schemas [[Special:JsonFormsManage/Schemas|here]]",
					"x-description-format": "wikitext",
					"default": "",
					"x-format": "text",
					"x-input": "OO.ui.DropdownInputWidget",
					"x-enum-provider": "jsonSchemas"
				},
				"preview": {
					"x-css-class": "jsonforms-editdata-preview",
					"x-compact": "true",
					"x-watch": "schema",
					"links": [
						{
							"rel": "describedBy",
							"href": "JsonSchema:{{schema}}",
							"x-destroy-values-on-switch": true
						}
					]
				}
			}
		}
	},
	"properties": {
		"form": {
			"title": "",
			"description": "The data will be saved in the main slot as json content-model.",
			"properties": {
				"title": {
					"type": "string",
					"minLength": 1,
					"x-input": "mw.widgets.TitleInputWidget"
				},
				"schema": {
					"type": "object",
					"x-compact": true,
					"additionalProperties": {
						"type": "object",
						"x-compact": true,
						"properties": {
							"schemaName": {
								"type": "string",
								"x-format": "hidden"
							},
							"editor": {
								"x-watch": "schemaName",
								"links": [
									{
										"rel": "describedBy",
										"href": "JsonSchema:{{schemaName}}"
									}
								]
							}
						}
					},
					"maxProperties": 1,
					"x-ui-schema": {
						"label": "New schema",
						"schema": "#/definitions/newSchema",
						"name": "newSchema",
						"popup_size": "large"
					}
				},
				"categories": {
					"type": "array",
					"x-collapsible": true,
					"items": {
						"type": "string",
						"x-input": "categorymultiselect"
					}
				}
			},
			"required": [ "schema", "title" ]
		},
		"footer": {
			"x-compact": true,
			"x-css-class": "jsonforms-outerform-footer",
			"properties": {
				"summary": {
					"type": "string"
				},
				"minor": {
					"type": "boolean",
					"title": "",
					"description": "",
					"description": "This is a [https://www.mediawiki.org/wiki/Help:Minor_edit minor edit]",
					"x-description-format": "wikitext",
					"x-input": "checkbox",
					"x-control-config": {
						"align": "inline"
					}
				},
				"buttons": {
					"type": "object",
					"x-layout": "horizontal",
					"x-compact": true,
					"x-css-class": "jsonforms-outerform-footer-buttons",
					"properties": {
						"submit": {
							"type": "null",
							"title": "Save changes",
							"x-format": "button",
							"x-button-action": "submitButton",
							"x-input-config": {
								"flags": ["primary", "progressive"]
							}
						}
					}
				}
			}
		}
	}
}

