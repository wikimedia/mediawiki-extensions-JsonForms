{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "NewProperty",
    "title": "New property",
    "type": "object",
    "required": [
        "name",
        "type"
    ],
    "x-defaultProperties": [
        "name",
        "type",
        "multiple"
    ],
    "properties": {
        "name": {
            "title": "Property name",
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
            "title": "type",
            "type": "string",
            "x-input": "RadioSelectInputWidget",
            "description": "Select the type of property",
            "enum": [
                "text",
                "number",
                "integer",
                "date",
                "datetime-local",
                "time",
                "boolean",
                "textarea",
                "email",
                "color",
                "range",
                "tel",
                "url",
                "json",
                "object"
            ],
            "x-enum-titles": [
                "Text",
                "Number",
                "Integer",
                "Date",
                "Datetime-local",
                "Time",
                "Boolean",
                "Textarea",
                "Email",
                "Color",
                "Range",
                "Tel",
                "Url",
                "Json",
                "Subitem"
            ]
        },
        "multiple": {
            "title": "multiple",
            "type": "boolean",
            "description": "allows multiple values"
        }
    }
}

