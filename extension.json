{
	"name": "JsonForms",
	"author": "thomas-topway-it",
	"version": "1.1.1",
	"url": "https://www.mediawiki.org/wiki/Extension:JsonForms",
	"descriptionmsg": "jsonforms-extension-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "parserhook",
	"requires": {
		"MediaWiki": ">= 1.39.13",
		"extensions": {}
	},
	"MessagesDirs": {
		"JsonForms": [ "i18n" ]
	},
	"callback": "JsonFormsHooks::initExtension",
	"Actions": {
		"slotedit": "JsonFormsActionSlotManager",
		"jsonedit": "JsonFormsActionJsonEdit"
	},
	"AutoloadClasses": {
		"SpecialJsonForms": "includes/specials/SpecialJsonForms.php",
		"JsonFormsActionSlotManager": "includes/JsonFormsActionSlotManager.php",
		"JsonFormsActionJsonEdit": "includes/JsonFormsActionJsonEdit.php",
		"SpecialJsonFormsDemo": "includes/specials/SpecialJsonFormsDemo.php",
		"SpecialJsonFormsCreate": "includes/specials/SpecialJsonFormsCreate.php",
		"SpecialJsonFormsEdit": "includes/specials/SpecialJsonFormsEdit.php",
		"SpecialJsonFormsManage": "includes/specials/SpecialJsonFormsManage.php",
		"SpecialJsonFormsSlotManager": "includes/specials/SpecialJsonFormsSlotManager.php",
		"JsonForms": "includes/JsonForms.php",
		"JsonFormsHooks": "includes/JsonFormsHooks.php",
		"JsonFormsApiFetchSchema": "includes/api/JsonFormsApiFetchSchema.php",
		"JsonFormsApiProcessSchema": "includes/api/JsonFormsApiProcessSchema.php",
		"JsonFormsApiSubmitForm": "includes/api/JsonFormsApiSubmitForm.php",
		"JsonFormsApiGroupNames": "includes/api/JsonFormsApiGroupNames.php"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\JsonForms\\": "includes/classes/",
		"MediaWiki\\Extension\\JsonForms\\Aliases\\": "includes/aliases/",
		"MediaWiki\\Extension\\JsonForms\\Utils\\": "includes/utils/",
		"MediaWiki\\Extension\\JsonForms\\Specials\\": "includes/specials/",
		"MediaWiki\\Extension\\JsonForms\\SubmitProcessors\\": "includes/classes/SubmitProcessors/"
	},
	"APIModules": {
		"jsonforms-fetch-schema": "JsonFormsApiFetchSchema",
		"jsonforms-process-schema": "JsonFormsApiProcessSchema",
		"jsonforms-submit-form": "JsonFormsApiSubmitForm",
		"jsonforms-groupnames": "JsonFormsApiGroupNames"
	},
	"ExtensionMessagesFiles": {
		"JsonFormsAlias": "JsonForms.alias.php",
		"JsonFormsMagic": "JsonFormsMagic.i18n.magic.php"
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "JsonFormsHooks::onLoadExtensionSchemaUpdates",
		"MediaWikiServices": "JsonFormsHooks::onMediaWikiServices",
		"ContentAlterParserOutput": "JsonFormsHooks::onContentAlterParserOutput",
		"BeforeInitialize": "JsonFormsHooks::onBeforeInitialize",
		"ParserFirstCallInit": "JsonFormsHooks::onParserFirstCallInit",
		"BeforePageDisplay": "JsonFormsHooks::onBeforePageDisplay",
