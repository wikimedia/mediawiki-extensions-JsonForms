				"OOJSPlus/widgets/ExpandablePanel.js",
				"OOJSPlus/widgets/RangeWidget.js"
			],
			"dependencies": [
				"mediawiki.rcfilters.filters.base.styles",
				"mediawiki.util",
				"mediawiki.base",
				"mediawiki.cookie",
				"mediawiki.api",
				"oojs-ui-core",
				"oojs-ui-widgets",
				"mediawiki.storage",
				"oojs-ui.styles.icons-alerts",
				"oojs-ui.styles.icons-interactions",
				"oojs-ui.styles.icons-editing-core",
