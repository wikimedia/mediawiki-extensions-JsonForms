		"OutputPageParserOutput": "JsonFormsHooks::onOutputPageParserOutput",
		"JsonForms::FormSubmitBeforeProcess": "JsonFormsHooks::onFormSubmitBeforeProcess",
		"JsonForms::FormSubmitBeforeSave": "JsonFormsHooks::onFormSubmitBeforeSave",
		"JsonForms::FormSubmitSuccess": "JsonFormsHooks::onJsonFormsFormSubmitSuccess"
	},
	"SpecialPages": {
		"JsonForms": "SpecialJsonForms",
		"JsonFormsCreate": "SpecialJsonFormsCreate",
		"JsonFormsEdit": "SpecialJsonFormsEdit",
		"JsonFormsDemo": "SpecialJsonFormsDemo",
		"JsonFormsManage": "SpecialJsonFormsManage",
		"JsonFormsSlotManager": "SpecialJsonFormsSlotManager",
		"JsonFormsManageForms": "MediaWiki\\Extension\\JsonForms\\Specials\\ManageForms",
		"JsonFormsManageSchemas": "MediaWiki\\Extension\\JsonForms\\Specials\\ManageSchemas"
	},
	"GroupPermissions": {
		"sysop": {
			"jsonforms-caneditdata": true,
			"jsonforms-canmanageschemas": true,
			"jsonforms-canmanageforms": true
		},
		"bureaucrat": {
			"jsonforms-caneditdata": true,
			"jsonforms-canmanageschemas": true,
			"jsonforms-canmanageforms": true
		},
		"jsonforms-editor": {
			"jsonforms-caneditdata": true,
			"jsonforms-canmanageschemas": true,
			"jsonforms-canmanageforms": true
		},
		"jsonforms-admin": {
			"jsonforms-caneditdata": true,
			"jsonforms-canmanageschemas": true,
			"jsonforms-canmanageforms": true
		},
		"*": {
			"jsonforms-caneditdata": true,
			"jsonforms-canmanageschemas": false,
			"jsonforms-canmanageforms": false
		}
	},
	"AddGroups": {
		"jsonforms-admin": [
			"jsonforms-admin",
			"jsonforms-editor"
		]
	},
	"RemoveGroups": {
		"jsonforms-admin": [
			"jsonforms-admin",
			"jsonforms-editor"
		]
	},
	"AvailableRights": [
		"jsonforms-caneditdata",
		"jsonforms-canmanageschemas",
		"jsonforms-canmanageforms"
	],
	"namespaces": [
		{
			"id": 2100,
			"constant": "NS_JSONSCHEMA",
			"name": "JsonSchema",
			"defaultcontentmodel": "json"
		},
		{
			"id": 2101,
			"constant": "NS_JSONSCHEMA_TALK",
			"name": "JsonSchemaTalk"
		},
		{
			"id": 2110,
			"constant": "NS_JSONDATA",
			"name": "JsonData",
			"defaultcontentmodel": "json"
		},
		{
			"id": 2111,
			"constant": "NS_JSONDATA_TALK",
			"name": "JsonDataTalk"
		},
		{
			"id": 2120,
			"constant": "NS_JSONFORM",
			"name": "JsonForm",
			"defaultcontentmodel": "json"
		},
		{
			"id": 2121,
			"constant": "NS_JSONFORM_TALK",
			"name": "JsonFormTalk"
		}
	],
	"JobClasses": {},
	"ResourceModules": {
